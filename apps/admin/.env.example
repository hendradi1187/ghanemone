# Ghanem.one Admin Tools — Environment Variables
# Copy to .env.local dan isi nilai aktual. JANGAN commit .env.local.
# Semua variabel VITE_* di-expose ke browser bundle — JANGAN simpan secret di sini.

# ---------------------------------------------------------------------------
# API Endpoints
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:3000/api/v1

# ---------------------------------------------------------------------------
# App Environment
# Nilai valid: dev | staging | production
# ---------------------------------------------------------------------------
VITE_APP_ENV=dev

# ---------------------------------------------------------------------------
# Sentry (APM — opsional di dev, wajib di staging + prod)
# ---------------------------------------------------------------------------
VITE_SENTRY_DSN=
