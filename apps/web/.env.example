# Ghanem.one Web App — Environment Variables
# Copy to .env.local dan isi nilai aktual. JANGAN commit .env.local.
# Semua variabel VITE_* di-expose ke browser bundle — JANGAN simpan secret di sini.

# ---------------------------------------------------------------------------
# API Endpoints
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:3000/api/v1
VITE_TILE_SERVER_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Map Provider
# Kosongkan untuk pakai Leaflet + OSM (default, tidak perlu token).
# Isi untuk aktifkan Mapbox GL (lihat docs/decisions/0004-tech-stack-finalize.md).
# ---------------------------------------------------------------------------
VITE_MAPBOX_TOKEN=

# ---------------------------------------------------------------------------
# App Environment
# Nilai valid: dev | staging | production
# ---------------------------------------------------------------------------
VITE_APP_ENV=dev

# ---------------------------------------------------------------------------
# Feature Flags
# Boolean string: "true" | "false"
# ---------------------------------------------------------------------------
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_3D_SEISMIC=false

# ---------------------------------------------------------------------------
# Sentry (APM — opsional di dev, wajib di staging + prod)
# Dapatkan DSN dari self-hosted Sentry di infra cluster.
# ---------------------------------------------------------------------------
VITE_SENTRY_DSN=
