{
  "name": "@ghanem/api",
  "version": "0.0.0",
  "private": true,
  "description": "Ghanem.one REST API + WebSocket gateway (NestJS + TypeScript). Spatial workload diserahkan ke apps/workers via BullMQ.",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "test": "jest --config jest.config.ts --passWithNoTests",
    "test:watch": "jest --config jest.config.ts --watch --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:geo": "prisma db execute --file prisma/migrations/20260528000000_add-geospatial-tables/migration.sql --schema prisma/schema.prisma",
    "prisma:seed:geo": "ts-node --project tsconfig.json prisma/seed-geospatial.ts",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "start:dev": "nest start --watch",
    "test:e2e": "jest --config jest.e2e.config.ts --passWithNoTests",
    "search:reindex": "ts-node --project tsconfig.json prisma/reindex-search.ts"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.json -e \"require('tsconfig-paths/register')\" prisma/seed.ts && ts-node --project tsconfig.json prisma/seed-geospatial.ts"
  },
  "dependencies": {
    "@ghanem/types": "*",
    "@nestjs/common": "^10.4.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.4.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.19.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.12.12",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.10.1",
    "joi": "^18.2.1",
    "meilisearch": "^0.45.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ghanem/config": "*",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.1",
    "@types/bcrypt": "^6.0.0",
    "@types/geojson": "^7946.0.14",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.16.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
