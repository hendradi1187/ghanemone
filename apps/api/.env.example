# Ghanem.one API Service — Environment Variables
# Copy to .env dan isi nilai aktual. JANGAN commit .env.
# Di production, semua variabel ini di-inject via Kubernetes Secrets / Vault Agent.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database — PostgreSQL 16 + PostGIS 3.4
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?schema=<schema>
# Local dev: jalankan `npm run dev:infra` untuk spin up PostgreSQL via Docker.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://ghanem:dev@localhost:5433/ghanem_dev?schema=public

# ---------------------------------------------------------------------------
# Redis 7 — queue (BullMQ) + cache
# Local dev: di-include di docker-compose.dev.yml
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Auth — JWT + OIDC (SKK Migas SSO di production)
# JWT_SECRET: generate dengan `openssl rand -base64 64` di prod.
# OIDC_*: koordinasi dengan tim IT SKK Migas untuk client credentials.
# ---------------------------------------------------------------------------
JWT_SECRET=replace-with-strong-secret-in-production
JWT_EXPIRES_IN=24h
OIDC_ISSUER=https://sso.skkmigas.go.id
OIDC_CLIENT_ID=ghanem-platform
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# ---------------------------------------------------------------------------
# Object Storage — MinIO (S3-compatible, self-hosted on-prem)
# Local dev: di-include di docker-compose.dev.yml (port 9000)
# Console UI: http://localhost:9001 (user: minioadmin / minioadmin — DEV ONLY)
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ghanem-uploads
MINIO_USE_SSL=false

# ---------------------------------------------------------------------------
# Search — Meilisearch v1.10
# Local dev: di-include di docker-compose.dev.yml (port 7700)
# MEILISEARCH_KEY: master key, ganti di staging/prod.
# ---------------------------------------------------------------------------
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=masterKey-replace-in-prod

# ---------------------------------------------------------------------------
# AI Proxy — Anthropic Claude
# CLAUDE_API_KEY: dapatkan dari https://console.anthropic.com
# Di prod, gunakan secret rotation via Vault (lihat docs/runbooks/secret-rotation.md).
# ---------------------------------------------------------------------------
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_RATE_LIMIT_PER_MIN=60

# ---------------------------------------------------------------------------
# CORS
# Comma-separated list origin yang diizinkan.
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
